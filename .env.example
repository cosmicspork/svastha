# Svastha local development.
#
# .env is gitignored — never commit a real mnemonic here or anywhere else; it
# is the master secret for an identity's keys.

# Relay (local dev) listen address.
SVASTHA_RELAY_ADDR=127.0.0.1:8787

# --- just decrypt (crates/devtool): pull one identity's relay blobs and
# decrypt them locally for inspection ---

# The identity whose relay blobs `just decrypt` pulls. The placeholder below
# is BIP39's canonical all-zero-entropy test mnemonic, not a real secret —
# replace it with your own before running against real data.
SVASTHA_MNEMONIC="abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon abandon about"

# Relay to pull from.
SVASTHA_RELAY_URL=http://127.0.0.1:8787

# Where decrypted output is written. Defaults to private/decrypt (gitignored
# via /private/) if unset; uncomment to override.
# SVASTHA_DECRYPT_OUT=private/decrypt
